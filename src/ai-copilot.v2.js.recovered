16: def clean_line_prefixes(lines):
- **Hội thoại liên tục**: Sử dụng `window.conversationContext` để ghi nhớ khối văn bản đang phân tích và hỗ trợ chuỗi câu hỏi nối tiếp (*"Còn điểm mù nào nữa?"*, *"Nếu loại bỏ cảm xúc?"*, *"Điểm nào nghiêm trọng nhất?"*) mà không cần người dùng chọn lại.
cleaned = []
for line in lines:
# Check if the line has line number prefix like "  1: /**" or "  1045:"
match = re.match(r'^\s*(\d+):(.*)$', line)
if match:
# We append the matched text with a newline
# match.group(2) contains the code without the line prefix
cleaned.append(match.group(2) + "\n")
return cleaned
